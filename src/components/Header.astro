---
---

<div class="ticker-bar">
  <div class="ticker-track">
    <span>NOW HIRING FULL-TIME &amp; PART-TIME STYLISTS &nbsp;&#9733;&nbsp; VISIT OUR CAREERS PAGE FOR DETAILS AND TO APPLY &nbsp;&#9733;&nbsp; NOW HIRING FULL-TIME &amp; PART-TIME STYLISTS &nbsp;&#9733;&nbsp; VISIT OUR CAREERS PAGE FOR DETAILS AND TO APPLY &nbsp;&#9733;&nbsp; WE HAVE ROOMS FOR RENT &nbsp;&#9733;&nbsp;</span>
  </div>
</div>

<header class="header">
  <a class="logo-link home-button">
    <img src="/koo_salon.svg" alt="Koo's Wigs & Design logo" class="logo" />
  </a>

  <nav class="nav-links">
    <a class="home-button">Home</a>
    <a class="contact-button">Contact</a>
  </nav>

  <div class="header-ctas">
    <a class="cta-outline contact-button">Contact Us</a>
  </div>
</header>

<style>
  .ticker-bar {
    background-color: var(--color-dark);
    overflow: hidden;
    white-space: nowrap;
    padding: 8px 0;
  }

  .ticker-track {
    display: inline-block;
    animation: ticker 30s linear infinite;
    color: #778DA9;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  @keyframes ticker {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background-color: #1B263B;
    padding: 0 3rem;
    height: 72px;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 20px rgba(0,0,0,0.3);
  }

  .logo-link {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    cursor: pointer;
  }

  .logo {
    height: 48px;
    width: auto;
    filter: brightness(0) invert(1);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .nav-links a {
    color: #E0E1DD;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: color 0.2s ease;
    white-space: nowrap;
  }

  .nav-links a:hover {
    color: var(--color-teal-light);
  }

  .home-button,
  .contact-button {
    cursor: pointer;
  }

  .header-ctas {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .cta-outline {
    color: var(--color-teal-light);
    border: 1.5px solid var(--color-teal-light);
    border-radius: 50px;
    padding: 0.45rem 1.2rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .cta-outline:hover {
    background-color: var(--color-teal-light);
    color: #fff;
  }

  @media (max-width: 768px) {
    .header {
      padding: 0 1.5rem;
    }
    .header-ctas {
      display: none;
    }
  }
</style>

<script>
  document.querySelectorAll('.contact-button').forEach(el => {
    el.addEventListener('click', () => {
      document.getElementById('visiting')?.scrollIntoView({
        behavior: 'smooth',
        block: 'start'
      });
    });
  });

  document.querySelectorAll('.home-button').forEach(el => {
    el.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });
</script>
