---

<div class="ticker-bar">
  <div class="ticker-track">
    <span>NOW HIRING FULL-TIME &amp; PART-TIME STYLISTS &nbsp;&#9733;&nbsp; VISIT OUR CAREERS PAGE FOR DETAILS AND TO APPLY &nbsp;&#9733;&nbsp; NOW HIRING FULL-TIME &amp; PART-TIME STYLISTS &nbsp;&#9733;&nbsp; VISIT OUR CAREERS PAGE FOR DETAILS AND TO APPLY &nbsp;&#9733;&nbsp; [ADD ANNOUNCEMENT TEXT HERE] &nbsp;&#9733;&nbsp; [ADD ANNOUNCEMENT TEXT HERE] &nbsp;&#9733;&nbsp;</span>
  </div>
</div>

<header class="header">
  <a href="/" class="logo-link">
    <img src="/koo_salon.svg" alt="Koo's Wigs & Design logo" class="logo" />
  </a>

  <nav class="nav-links">
    <a href="/">Home</a>
    <a href="/about">About</a>
    <a href="/faq">FAQ</a>
    <a href="/contact">Contact</a>
  </nav>

  <div class="header-ctas">
    <a href="/contact" class="cta-outline">Contact Us</a>
    <a href="/about" class="cta-solid">Our Story</a>
  </div>

  <button class="hamburger" id="hamburger-btn" aria-label="Open menu">
    <span></span><span></span><span></span>
  </button>
</header>

<div class="mobile-menu" id="mobile-menu">
  <button class="mobile-close" id="mobile-close">&#x2715;</button>
  <nav class="mobile-nav">
    <a href="/">Home</a>
    <a href="/about">About</a>
    <a href="/faq">FAQ</a>
    <a href="/contact">Contact</a>
  </nav>
</div>

<style>
  .ticker-bar {
    background-color: var(--color-dark);
    overflow: hidden;
    white-space: nowrap;
    padding: 8px 0;
  }

  .ticker-track {
    display: inline-block;
    animation: ticker 30s linear infinite;
    color: #778DA9;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  @keyframes ticker {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background-color: #1B263B;
    padding: 0 3rem;
    height: 72px;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 20px rgba(0,0,0,0.3);
  }

  .logo-link {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .logo {
    height: 48px;
    width: auto;
    filter: brightness(0) invert(1);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .nav-links a {
    color: #E0E1DD;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: color 0.2s ease;
    white-space: nowrap;
  }

  .nav-links a:hover {
    color: var(--color-teal-light);
  }

  .header-ctas {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .cta-outline {
    color: var(--color-teal-light);
    border: 1.5px solid var(--color-teal-light);
    border-radius: 50px;
    padding: 0.45rem 1.2rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .cta-outline:hover {
    background-color: var(--color-teal-light);
    color: #fff;
  }

  .cta-solid {
    background-color: var(--color-teal);
    color: #fff;
    border: 1.5px solid var(--color-teal);
    border-radius: 50px;
    padding: 0.45rem 1.2rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .cta-solid:hover {
    background-color: var(--color-teal-light);
    border-color: var(--color-teal-light);
  }

  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .hamburger span {
    display: block;
    width: 24px;
    height: 1.5px;
    background-color: #E0E1DD;
    transition: all 0.2s;
  }

  .mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    background-color: #1B263B;
    z-index: 200;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .mobile-menu.open {
    display: flex;
  }

  .mobile-close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: none;
    border: none;
    color: #E0E1DD;
    font-size: 1.5rem;
    cursor: pointer;
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .mobile-nav a {
    color: #E0E1DD;
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .header {
      padding: 0 1.5rem;
    }
    .nav-links {
      display: none;
    }
    .header-ctas {
      display: none;
    }
    .hamburger {
      display: flex;
    }
  }
</style>

<script>
  const btn = document.getElementById('hamburger-btn');
  const menu = document.getElementById('mobile-menu');
  const close = document.getElementById('mobile-close');
  btn?.addEventListener('click', () => menu?.classList.add('open'));
  close?.addEventListener('click', () => menu?.classList.remove('open'));
</script>
