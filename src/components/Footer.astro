---
const address = "westfield wheaton maryland";
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address)}`;
---

<footer class="footer">
  <div class="footer-inner">

    <div class="footer-brand">
      <img src="/koo_salon.svg" alt="Koo's Wigs & Design" class="footer-logo" />
      <p class="footer-tagline">Beautiful & Quality.</p>
      <p class="footer-tagline-sub">Wheaton, MD</p>
    </div>

    <div class="footer-col">
      <p class="footer-col-title">Visit Us</p>
      <a href={mapsUrl} target="_blank" class="footer-link">
        11160 Veirs Mill Rd<br />
        Wheaton, MD 20902
      </a>
      <p class="footer-note">Inside Wheaton Mall<br />Ground floor, next to Target</p>
    </div>

    <div class="footer-col">
      <p class="footer-col-title">Contact</p>
      <a href="tel:3019334522" class="footer-link">(301) 933-4522</a>
    </div>

    <div class="footer-col">
      <p class="footer-col-title">Hours</p>
      <table class="footer-hours">
        <tr><td>Mon – Thu</td><td>10AM – 8PM</td></tr>
        <tr><td>Fri – Sat</td><td>10AM – 9PM</td></tr>
        <tr><td>Sun</td><td>11AM – 7PM</td></tr>
      </table>
    </div>

    <div class="footer-col">
      <p class="footer-col-title">Navigate</p>
      <nav class="footer-nav">
        <button class="footer-nav-link footer-nav-btn" id="footer-home-btn">Home</button>
        <button class="footer-nav-link footer-nav-btn" id="footer-contact-btn">Contact</button>
      </nav>
    </div>

  </div>

  <div class="footer-bottom">
    <p>&copy; 2026 Koo's Wigs &amp; Design. All Rights Reserved.</p>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-navy);
    color: #778DA9;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 5rem 4rem 3rem;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .footer-brand {}

  .footer-logo {
    height: 48px;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.85;
    display: block;
    margin-bottom: 1rem;
  }

  .footer-tagline {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 300;
    font-style: italic;
    color: #E0E1DD;
    margin: 0 0 0.25rem;
  }

  .footer-tagline-sub {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-teal-light);
    margin: 0;
  }

  .footer-col-title {
    font-family: var(--font-sans);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #E0E1DD;
    margin: 0 0 1.2rem;
  }

  .footer-link {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 300;
    line-height: 1.7;
    color: #778DA9;
    display: block;
    margin-bottom: 0.5rem;
    transition: color 0.2s;
  }

  .footer-link:hover {
    color: var(--color-teal-light);
  }

  .footer-note {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 300;
    line-height: 1.6;
    color: #415A77;
    font-style: italic;
    margin: 0;
  }

  .footer-hours {
    border-spacing: 0;
    border-collapse: collapse;
  }

  .footer-hours td {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 300;
    color: #778DA9;
    padding: 0.2rem 1rem 0.2rem 0;
    line-height: 1.6;
  }

  .footer-hours tr td:first-child {
    color: #415A77;
    white-space: nowrap;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-nav-link {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 300;
    color: #778DA9;
    transition: color 0.2s;
  }

  .footer-nav-link:hover {
    color: var(--color-teal-light);
  }

  .footer-nav-btn {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-align: left;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.07);
    padding: 1.5rem 4rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-bottom p {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 300;
    letter-spacing: 0.08em;
    color: #415A77;
    margin: 0;
    text-align: center;
  }

  @media (max-width: 1024px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr 1fr;
      padding: 4rem 2rem 2rem;
    }
    .footer-bottom {
      padding: 1.5rem 2rem;
    }
  }

  @media (max-width: 640px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }
</style>

<script>
  const visitingSection = document.getElementById('visiting');

  document.querySelector('.footer-nav')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('button');
    if (!btn) return;
    if (btn.id === 'footer-home-btn') {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    } else if (btn.id === 'footer-contact-btn') {
      visitingSection?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });
</script>
