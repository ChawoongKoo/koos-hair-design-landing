---
const address = "westfield wheaton maryland";
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address)}`;

import AddressIcon from "../icons/AddressIcon.astro";
import PhoneIcon from "../icons/PhoneIcon.astro";
---

<section class="visiting" id="visiting">
  <div class="visiting-inner">

    <!-- Left: image with teal accent block -->
    <div class="visiting-image-col">
      <div class="teal-accent"></div>
      <div class="image-frame">
        <img
          src="/kooswigsphotos/IMG_3923.png"
          alt="Koo's Wigs & Design salon interior"
          class="salon-img"
        />
      </div>
    </div>

    <!-- Right: text content -->
    <div class="visiting-text-col">
      <p class="label-text">Come Find Us</p>
      <h2 class="visiting-heading">
        <span class="serif-display">The Place</span>
        <span class="visiting-heading-sub">to be your best.</span>
      </h2>

      <p class="visiting-intro">
        We're located inside Wheaton Mall — find us on the ground floor, right next to Target.
      </p>

      <div class="visiting-details">
        <div class="detail-row">
          <span class="detail-icon"><AddressIcon /></span>
          <div>
            <a href={mapsUrl} target="_blank" class="detail-link">
              11160 Veirs Mill Rd<br />
              Wheaton, MD 20902
            </a>
            <a href={mapsUrl} target="_blank" class="maps-text">View on Google Maps ↗</a>
          </div>
        </div>

        <div class="detail-row">
          <span class="detail-icon"><PhoneIcon /></span>
          <a href="tel:3019334522" class="detail-link">(301) 933-4522</a>
        </div>
      </div>

      <div class="hours-block">
        <p class="hours-title label-text">Hours</p>
        <table class="hours-table">
          <tr><td>Monday – Thursday</td><td>10:00 AM – 8:00 PM</td></tr>
          <tr><td>Friday – Saturday</td><td>10:00 AM – 9:00 PM</td></tr>
          <tr><td>Sunday</td><td>11:00 AM – 7:00 PM</td></tr>
        </table>
      </div>
    </div>

  </div>
</section>

<style>
  .visiting {
    background-color: var(--color-white);
    padding: 7rem 0;
    overflow: hidden;
  }

  .visiting-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 4rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  /* --- Image column --- */
  .visiting-image-col {
    position: relative;
    padding-top: 2rem;
    padding-left: 1.5rem;
  }

  .teal-accent {
    position: absolute;
    top: 0;
    left: 0;
    width: 58%;
    height: 88%;
    background-color: var(--color-teal-muted);
    z-index: 0;
  }

  .image-frame {
    position: relative;
    z-index: 1;
    margin-left: 1.5rem;
    margin-top: 1.5rem;
    box-shadow: 0 20px 60px rgba(0,0,0,0.14);
  }

  .salon-img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  /* --- Text column --- */
  .visiting-text-col {
    padding-left: 1rem;
  }

  .visiting-heading {
    display: flex;
    flex-direction: column;
    margin: 0.6rem 0 1.5rem;
    line-height: 1.05;
  }

  .visiting-heading .serif-display {
    font-family: var(--font-serif);
    font-size: clamp(2.8rem, 4vw, 4rem);
    font-weight: 400;
    color: var(--color-teal);
  }

  .visiting-heading-sub {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-top: 0.4rem;
  }

  .visiting-intro {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text-muted);
    margin: 0 0 2rem;
    max-width: 380px;
  }

  .visiting-details {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .detail-row {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .detail-icon {
    color: var(--color-teal);
    margin-top: 2px;
    flex-shrink: 0;
  }

  .detail-link {
    font-family: var(--font-sans);
    font-size: 0.88rem;
    font-weight: 400;
    color: var(--color-text);
    line-height: 1.6;
    display: block;
  }

  .detail-link:hover {
    color: var(--color-teal);
  }

  .maps-text {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--color-teal);
    font-style: italic;
    display: block;
    margin-top: 0.2rem;
  }

  .maps-text:hover {
    color: var(--color-teal-light);
  }

  .hours-block {
    border-top: 1px solid #E0E1DD;
    padding-top: 1.5rem;
  }

  .hours-title {
    margin: 0 0 0.75rem;
  }

  .hours-table {
    border-spacing: 0;
    border-collapse: collapse;
  }

  .hours-table td {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 300;
    color: var(--color-text);
    padding: 0.3rem 1.5rem 0.3rem 0;
    line-height: 1.6;
  }

  .hours-table tr td:first-child {
    color: var(--color-text-muted);
  }

  @media (max-width: 900px) {
    .visiting-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
      padding: 0 2rem;
    }
    .visiting-image-col {
      max-width: 480px;
      margin: 0 auto;
    }
  }
</style>
